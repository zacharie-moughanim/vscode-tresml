{
  "name": "tresml",
  "displayName": "TresML",
  "description": "TresML language extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tresml.unesuperfonction",
        "title": "Une super fonction"
      }
    ],
    "languages": [
      {
        "id": "tresml",
        "extensions": [".tml"],
        "aliases": ["TresML"],
        "filenames": [],
        "icon": {
          "light": "./icons/tresml_light.svg",
          "dark": "./icons/tresml_dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "tresml",
        "scopeName": "source.tml",
        "path": "./syntaxes/tresml.tmGrammar.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
