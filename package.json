{
  "name": "tresml",
  "displayName": "TresML",
  "description": "Official TresML language extension",
  "categories": [
    "Programming Languages"
  ],
  "publisher": "tresml-lang",
  "icon": "./icons/tresml_with_name.png",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zacharie-moughanim/vscode-tresml.git"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [],
    "languages": [
      {
        "id": "tresml",
        "extensions": [
          ".tml"
        ],
        "aliases": [
          "TresML"
        ],
        "filenames": [],
        "configuration": "./tml-language-configuration.json",
        "icon": {
          "light": "./icons/tresml_light.svg",
          "dark": "./icons/tresml_dark.svg"
        }
      },
      {
        "id": "tresml_script",
        "configuration": "./tml-scr-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tresml",
        "scopeName": "source.tml",
        "path": "./syntaxes/tresml.tmGrammar.json",
        "embeddedLanguages": {
          "meta.embedded.html": "html"
        }
      },
      {
        "scopeName": "tresml.tresml_script.block",
        "path": "./syntaxes/tresml_script_embedded.tmGrammar.json",
        "injectTo": [
          "source.tml"
        ],
        "embeddedLanguages": {
          "meta.embedded.tresml_script": "tresml_script"
        }
      },
      {
        "language": "tresml_script",
        "scopeName": "source.tml_scr",
        "path": "./syntaxes/tresml_script.tmGrammar.json",
        "embeddedLanguages": {
          "meta.embedded.tresml": "tresml",
          "meta.embedded.js": "javascript",
          "meta.embedded.html": "html"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "vsce": "^2.15.0"
  }
}
