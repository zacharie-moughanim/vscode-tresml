{
  "name": "tresml",
  "displayName": "TresML",
  "description": "Official TresML language extension",
  "categories": [
    "Programming Languages"
  ],
  "publisher": "tresml-lang",
  "icon": "./icons/tresml_with_name.png",
  "version": "1.2.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zacharie-moughanim/vscode-tresml.git"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tresml.compile",
        "title": "Export to HTML",
        "category": "TresML",
        "icon": "$(file-code)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "when": "resourceLangId == tresml && editorTextFocus",
          "command": "tresml.compile"
        }
      ]
    },
    "configuration": {
      "title": "TresML",
      "type": "object",
      "properties": {
        "TresML.tmlInterpreter.version": {
          "type": "string",
          "markdownDescription": "Which version of the TresML interpreter to use.\n\nThe native assembly interpreter requires no dependency, but check if your configuration is supported in the extension's README.\n\nThe bytecode can be used on any machine and system, but you need to have an [OCaml intepreter](https://ocaml.org/install) installed, see the dependencies in the README.",
          "enum": ["Native", "Bytecode"],
          "default": "Native",
          "comment": "add option WASM when implemented",
          "order": 0
        },
        "TresML.tmlInterpreter.machineArchitecture": {
          "type": "string",
          "markdownDescription": "If you selected the `Native` version of the TresML interpreter, select the architecture of your machine's CPU. The only choices displayed are the supported architecture for the native compiled interpreter. (If you didn't select `Native` this setting is ignored).",
          "default": "x86_64",
          "enum": ["x86_64"],
          "order": 1
        }
      }
    },
    "languages": [
      {
        "id": "tresml",
        "extensions": [
          ".tml"
        ],
        "aliases": [
          "TresML"
        ],
        "filenames": [],
        "configuration": "./tml-language-configuration.json",
        "icon": {
          "light": "./icons/tresml_light.svg",
          "dark": "./icons/tresml_dark.svg"
        }
      },
      {
        "id": "tresml_script",
        "configuration": "./tml-scr-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tresml",
        "scopeName": "source.tml",
        "path": "./syntaxes/tresml.tmGrammar.json",
        "embeddedLanguages": {
          "meta.embedded.html": "html"
        }
      },
      {
        "scopeName": "tresml.tresml_script.block",
        "path": "./syntaxes/tresml_script_embedded.tmGrammar.json",
        "injectTo": [
          "source.tml"
        ],
        "embeddedLanguages": {
          "meta.embedded.tresml_script": "tresml_script", "comment": "sthelse.tresml_script + tokenTypes / meta.embedded.tresml_script"
        }
      },
      {
        "language": "tresml_script",
        "scopeName": "source.tml_scr",
        "path": "./syntaxes/tresml_script.tmGrammar.json",
        "embeddedLanguages": {
          "meta.embedded.tresml": "tresml",
          "meta.embedded.js": "javascript",
          "meta.embedded.html": "html"
        },
        "tokenTypes": {
          "comment.block.tml": "comment"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "glob": "^11.0.0",
    "vsce": "^1.97.0",
    "vscode-languageclient": "^9.0.1"
  }
}
