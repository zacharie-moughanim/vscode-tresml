{
  "comments": {
    // "lineComment": "//",
    "blockComment": ["(*", "*)"]
  },
  "brackets": [
    ["%{", "}%"],
    ["<[", "]>"],
    ["<{", "}>"],
    // ["[", "]"],
    // ["{", "}"],
    ["(", ")"],
    ["begin", "end"]
  ],
  "autoClosingPairs": [
    { "open": "begin", "close": "end" },
    { "open": "%{", "close": "}%" },
    { "open": "<{", "close": "}>" },
    { "open": "<[", "close": "]>" },
    { "open": "(*", "close": "*)" },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    // { "open": "'", "close": "'", "notIn": ["string", "comment"] }, TODO add this when chars are part of tresml
    { "open": "\"", "close": "\"", "notIn": ["string"] },
  ],
  "autoCloseBefore": ";:.,=}])>` \n\t",
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    // ["'", "'"], TODO add this when chars are part of tresml
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region\\b",
      "end": "^\\s*//\\s*#?endregion\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^((?!\\/\\/).)*(\\{[^}\"'`]*|\\([^)\"'`]*|\\[[^\\]\"'`]*)|begin^end$",
    "decreaseIndentPattern": "^((?!.*?\\/\\*).*\\*/)?\\s*[\\)\\}\\]].*$"
  }
}