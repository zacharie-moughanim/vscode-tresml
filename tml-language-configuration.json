{
  // "comments": {
  //   "lineComment": "//",
  //   "blockComment": ["/*", "*/"]
  // },
  "brackets": [
    ["%{", "}%"],
    ["<[", "]>"],
    ["<{", "}>"],
    // ["[", "]"],
    // ["{", "}"],
    ["(", ")"],
    ["begin", "end"]
  ],
  "autoClosingPairs": [
    { "open": "<{", "close": "}>", "comment": "this is actually useless" },
    { "open": "<[", "close": "]>" },
    { "open": "<", "close": ">" },
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "begin", "close": "end" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
  ],
  "autoCloseBefore": ";:.,=}])>` \n\t",
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region\\b",
      "end": "^\\s*//\\s*#?endregion\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^((?!\\/\\/).)*(\\{[^}\"'`]*|\\([^)\"'`]*|\\[[^\\]\"'`]*)$",
    "decreaseIndentPattern": "^((?!.*?\\/\\*).*\\*/)?\\s*[\\)\\}\\]].*$"
  }
}