{
  "scopeName": "source.tml_scr",
  "patterns": [{ "include": "#expression" }],
  "repository": {
    "expression": {
      "patterns": [
        { "include": "#tresml_page-expression" },
        { "include": "#binding-word" },
        { "include": "#function-declaration-word" },
        { "include": "#control-flow-keyword" },
        { "include": "#beginend" },
        { "include": "#other-keyword" },
        { "include": "#integer-literal" },
        { "include": "#boolean-literal" },
        { "include": "#fstring-literal" },
        { "include": "#string-literal" },
        { "include": "#identifier" },
        { "include": "#Identifier" },
        { "include": "#period" },
        { "include": "#semicolon" },
        { "include": "#comma" },
        { "include": "#operators" },
        { "include": "#paren-expression" }
      ]
    },
    "tresml_page-expression": {
      "patterns": [
        {
          "name": "tml.html.block",
          "begin": "<\\[",
          "end": "\\]>",
          "contentName": "meta.embedded.html", "comment" : "not ideal, see why we can't recursively set the language to tml here, but seems ok",
          "patterns": [{ "include": "text.html.derivative" }]
        }
      ]
    },
    "beginend": {
      "match": "begin|end",
      "name": "keyword.other.tml"
    },
    "paren-expression": {
      "begin": "\\(|begin",
      "end": "\\)|end",
      "beginCaptures": {
        "0": { "name": "punctuation.paren.open" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.paren.close" }
      },
      "name": "expression.group",
      "patterns": [{ "include": "#expression" }]
    },
    "binding-word": {
      "match": "let",
      "name": "keyword.tml"
    },
    "function-declaration-word": {
      "match": "fun|fixfun",
      "name": "keyword.tml"
    },
    "control-flow-keyword": {
      "match": "if|then|else",
      "name": "keyword.control.tml"
    },
    "other-keyword": {
      "match": "in",
      "name": "keyword.tml"
    },
    "integer-literal": {
      "match": "[0-9][[0-9]_]*",
      "name": "constant.numeric.integer.tml"
    },
    "boolean-literal": {
      "match": "true|false",
      "name": "constant.numeric.boolean.tml", "comment": "FIXME: find better scope than 'numeric' for a boolean"
    },
    "fstring-literal": {
      "begin": "f\"",
      "end": "\"",
      "name": "string.quoted.double.tml fstring",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.tml", "comment": "FIXME: add each escape char and tag others as invalid.something"
        },
        {
          "begin": "%{",
          "end": "}%",
          "beginCaptures": {
            "0": { "name": "punctuation.fstring_code_embed.open" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.fstring_code_embed.close" }
          },
          "name": "meta.embedded.fstring.tresml_scr source.tml_scr",
          "patterns": [{ "include" : "#expression"}]
        }
      ]
    },
    "string-literal": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.tml",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.tml", "comment": "FIXME: add each escape char and tag others as invalid.something"
        }
      ]
    },
    "identifier": {
      "match": "[_[a-z]][[:alnum:]'_]*",
      "name": "entity.name.identifier.tml"
    },
    "Identifier": {
      "match": "[A-Z][[:alnum:]'_]*",
      "name": "constant.language.Identifier.tml"
    },
    "period": {
      "match": "\\.",
      "name": "punctuation.separator.period punctuation.other.period"
    },
    "semicolon": {
      "match": ";",
      "name": "punctuation.separator.semicolon punctuation.separator.terminator"
    },
    "comma": {
      "match": ",",
      "name": "punctuation.separator.comma punctuation.comma"
    },
    "operators": {
      "match": "->|\\+\\+|\\=|<>|\\+|\\-|\\*|\\/|\\^|>=|<=|>|<|&&|\\|\\|",
      "name": "keyword.operator.tml"
    }
  }
}
